{
    "name": "laravel/laravel",
    "description": "The Laravel Framework.",
    "keywords": [
        "framework",
        "laravel"
    ],
    "license": "MIT",
    "type": "project",
    "require": {
        "php": "^8.2",
        "doctrine/dbal": "^3.0",
        "fakerphp/faker": "^1.9.1",
        "intervention/image": "^2.5",
        "jedrzej/searchable": "dev-master",
        "kolydart/common": "^0.5.0",
        "kolydart/laravel": "dev-master",
        "laravel/framework": "^12.0",
        "laravel/tinker": "^2.9",
        "laravel/ui": "^4.5",
        "laravellux/html": "^7.1",
        "sentry/sentry-laravel": "^4.0",
        "spatie/laravel-activitylog": "^4.8",
        "spatie/laravel-medialibrary": "^11.0",
        "unisharp/laravel-filemanager": "^2.9",
        "yajra/laravel-datatables-oracle": "^12.0"
    },
    "require-dev": {
        "barryvdh/laravel-debugbar": "^3.10",
        "barryvdh/laravel-ide-helper": "^3.0",
        "laravel/boost": "^1.0",
        "laravel/dusk": "^8.0",
        "mockery/mockery": "^1.4.2",
        "nunomaduro/collision": "^8.1",
        "phpunit/phpunit": "^11.5",
        "roave/security-advisories": "dev-latest",
        "spatie/laravel-ignition": "^2.4",
        "symfony/thanks": "^1.0"
    },
    "autoload": {
        "classmap": [
            "database/seeds",
            "database/factories"
        ],
        "exclude-from-classmap": [],
        "psr-4": {
            "App\\": "app/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "dont-discover": []
        }
    },
    "scripts": {
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate"
        ],
        "post-update-cmd": [
            "Illuminate\\Foundation\\ComposerScripts::postUpdate"
        ],
        "post-update-cmd-dev": [
            "@php artisan ide-helper:generate",
            "@php artisan ide-helper:models --nowrite",
            "if [ ! -L vendor/kolydart/laravel ] ; then rm -rf vendor/kolydart/laravel && ln -s ../../../kolydart-laravel vendor/kolydart/laravel; fi",
            "if [ ! -L vendor/kolydart/common ] ; then rm -rf vendor/kolydart/common && ln -s ../../../kolydart-common vendor/kolydart/common; fi"
        ],
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover"
        ]
    },
    "config": {
        "preferred-install": "dist",
        "sort-packages": true,
        "optimize-autoloader": true,
        "allow-plugins": {
            "kylekatarnls/update-helper": true,
            "php-http/discovery": true,
            "symfony/thanks": true
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}